# TELEGRAM API keys
TELEGRAM_TOKEN=your_telegram_token

# LLM API keys
OPENROUTER_API_KEY=your_openrouter_api_key
OPENAI_API_KEY=your_openai_api_key

# LLM backend to use
# Options: OPENAI, OPENROUTER
# Uncomment the one you want to use and comment the other
LLM_BACKEND=OPENAI
#LLM_BACKEND=OPENROUTER

# Model name to use
# For OpenAI use: gpt-4, gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# For OpenRouter use: openai/gpt-4, openai/gpt-3.5-turbo
MODEL_NAME=gpt-4o-mini


# GSheets logging
GSHEETS_LOGGING_ENABLED=true
# Auth: choose ONE
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}   # single-line JSON
GOOGLE_APPLICATION_CREDENTIALS=D:\path\to\service_account.json

GSHEETS_SPREADSHEET_ID=your_sheet_id
GSHEETS_WORKSHEET=Logs
# Optional: fixed header order (defaults already match your spec)
# GSHEETS_FIELDS=DateTime,BotID,TelegramID,LLM,OptimizationModel,UserRequest,Answer,prompt_tokens,completion_tokens,total_tokens

# Optional: stable bot label for cross-bot sheets
BOT_ID=test-bot-1