# =============================================================================
# TELEGRAM BOT CONFIGURATION
# =============================================================================

# Required: Your Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_telegram_token

# Optional: Bot identifier for logging (useful for multiple bot instances)
BOT_ID=prompt-bot-1

# Optional: Initial system prompt (if needed)
INITIAL_PROMPT=You are a helpful assistant for prompt optimization.

# =============================================================================
# LLM BACKEND CONFIGURATION
# =============================================================================

# Required: Choose your LLM backend
# Options: OPENAI, OPENROUTER
LLM_BACKEND=OPENROUTER

# =============================================================================
# OPENAI CONFIGURATION (if using OPENAI backend)
# =============================================================================

# Required if LLM_BACKEND=OPENAI
OPENAI_API_KEY=your_openai_api_key

# Optional: OpenAI-specific settings
OPENAI_MAX_RETRIES=5
OPENAI_REQUEST_TIMEOUT=60.0
OPENAI_MAX_WAIT_TIME=300.0

# =============================================================================
# OPENROUTER CONFIGURATION (if using OPENROUTER backend)
# =============================================================================

# Required if LLM_BACKEND=OPENROUTER
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional: OpenRouter-specific settings
OPENROUTER_TIMEOUT=60.0

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Model name to use (backend-specific)
# For OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# For OpenRouter: openai/gpt-4, openai/gpt-3.5-turbo, anthropic/claude-3-sonnet
MODEL_NAME=openai/gpt-4

# =============================================================================
# GOOGLE SHEETS LOGGING (Optional)
# =============================================================================

# Enable/disable Google Sheets logging
GSHEETS_LOGGING_ENABLED=false

# Authentication: Choose ONE method
# Method 1: Service account JSON (single-line, escape quotes)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}

# Method 2: Path to service account file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service_account.json

# Spreadsheet configuration: Choose ONE method
# Method 1: Spreadsheet ID (recommended - more stable)
# GSHEETS_SPREADSHEET_ID=your_spreadsheet_id

# Method 2: Spreadsheet name
# GSHEETS_SPREADSHEET_NAME=Your Spreadsheet Name

# Worksheet settings
GSHEETS_WORKSHEET=Logs
GSHEETS_BATCH_SIZE=20
GSHEETS_FLUSH_INTERVAL_SECONDS=5.0

# Optional: Custom field order (defaults are optimized for the bot)
# GSHEETS_FIELDS=DateTime,BotID,TelegramID,LLM,OptimizationModel,UserRequest,Answer,prompt_tokens,completion_tokens,total_tokens