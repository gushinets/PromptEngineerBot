# =============================================================================
# TELEGRAM BOT CONFIGURATION
# =============================================================================

# Required: Your Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_telegram_token

# Optional: Bot identifier for logging (useful for multiple bot instances)
BOT_ID=prompt-bot-1

# Optional: Initial system prompt (if needed)
INITIAL_PROMPT=You are a helpful assistant for prompt optimization.

# =============================================================================
# LLM BACKEND CONFIGURATION
# =============================================================================

# Required: Choose your LLM backend
# Options: OPENAI, OPENROUTER
LLM_BACKEND=OPENROUTER

# =============================================================================
# OPENAI CONFIGURATION (if using OPENAI backend)
# =============================================================================

# Required if LLM_BACKEND=OPENAI
OPENAI_API_KEY=your_openai_api_key

# Optional: OpenAI-specific settings
OPENAI_MAX_RETRIES=5
OPENAI_REQUEST_TIMEOUT=60.0
OPENAI_MAX_WAIT_TIME=300.0

# =============================================================================
# OPENROUTER CONFIGURATION (if using OPENROUTER backend)
# =============================================================================

# Required if LLM_BACKEND=OPENROUTER
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional: OpenRouter-specific settings
OPENROUTER_TIMEOUT=60.0

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Model name to use (backend-specific)
# For OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# For OpenRouter: openai/gpt-4, openai/gpt-3.5-turbo, anthropic/claude-3-sonnet
MODEL_NAME=gpt-4o-mini

# Optional: Separate model/provider for audio transcription
# If empty, the bot will use MODEL_NAME and the selected LLM_BACKEND
BOT_MODEL_FOR_TRANSCRIPTION=openai/gpt-4o-mini-audio
OPENAI_BOT_MODEL_FOR_TRANSCRIPTION=whisper-1

# =============================================================================
# GOOGLE SHEETS LOGGING (Optional)
# =============================================================================

# Enable/disable Google Sheets logging
GSHEETS_LOGGING_ENABLED=false

# Authentication: Choose ONE method
# Method 1: Service account JSON (single-line, escape quotes)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}

# Method 2: Path to service account file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service_account.json

# Spreadsheet configuration: Choose ONE method
# Method 1: Spreadsheet ID (recommended - more stable)
# GSHEETS_SPREADSHEET_ID=your_spreadsheet_id

# Method 2: Spreadsheet name
# GSHEETS_SPREADSHEET_NAME=Your Spreadsheet Name

# Worksheet settings
GSHEETS_WORKSHEET=Logs
GSHEETS_BATCH_SIZE=20
GSHEETS_FLUSH_INTERVAL_SECONDS=5.0

# Optional: Custom field order (defaults are optimized for the bot)
# GSHEETS_FIELDS=DateTime,BotID,TelegramID,LLM,OptimizationModel,UserRequest,Answer,prompt_tokens,completion_tokens,total_tokens

# =============================================================================
# EMAIL FEATURE CONFIGURATION
# =============================================================================

# Enable/disable email authentication and delivery feature
EMAIL_ENABLED=true

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL credentials (used by Docker Compose)
# These are used to configure the PostgreSQL container and construct DATABASE_URL
POSTGRES_DB=botdb
POSTGRES_USER=botuser
POSTGRES_PASSWORD=your_secure_postgres_password_here

# Database connection URL
# For development (SQLite): sqlite:///./bot.db
# For production (PostgreSQL): postgresql://user:password@host:port/database
# Note: In Docker, this is constructed automatically from POSTGRES_* variables
DATABASE_URL=sqlite:///./bot.db

# Database connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_PRE_PING=true

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis password for authentication (used by Docker Compose)
# Required for production deployments
REDIS_PASSWORD=your_secure_redis_password_here

# Redis connection URL for OTP storage and rate limiting
# Note: In Docker, this is constructed automatically using REDIS_PASSWORD
REDIS_URL=redis://localhost:6379

# Redis connection pool settings
REDIS_MAX_CONNECTIONS=10

# Fail fast if Redis is not writable (recommended in production)
REDIS_WRITE_CHECK_STRICT=false


# =============================================================================
# SMTP CONFIGURATION
# =============================================================================

# SMTP server settings
SMTP_HOST=smtp-pulse.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password

# SMTP security settings (choose TLS or SSL, not both)
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Email sender information
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Prompt Engineering Bot

# =============================================================================
# EMAIL AUTHENTICATION SETTINGS
# =============================================================================

# OTP (One-Time Password) settings
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3

# Rate limiting settings
EMAIL_RATE_LIMIT_PER_HOUR=3
USER_RATE_LIMIT_PER_HOUR=5
OTP_SPACING_SECONDS=60

# =============================================================================
# AUDIT AND MONITORING SETTINGS
# =============================================================================

# Audit event retention
AUDIT_RETENTION_DAYS=90
AUDIT_PURGE_ENABLED=true

# =============================================================================
# CONVERSATION SETTINGS
# =============================================================================

# Follow-up conversation timeout
FOLLOWUP_TIMEOUT_SECONDS=300

# =============================================================================
# SESSION TRACKING SETTINGS
# =============================================================================

# Session timeout in seconds - sessions inactive for longer than this period
# will be automatically marked as unsuccessful (default: 86400 = 24 hours)
# SESSION_TIMEOUT_SECONDS=86400

# =============================================================================
# LOCALIZATION SETTINGS
# =============================================================================

# Bot language (EN or RU)
LANGUAGE=EN

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level for the application
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use DEBUG for development, INFO or WARNING for production
LOG_LEVEL=INFO

# =============================================================================
# MARKETING REPORTS CONFIGURATION
# =============================================================================

# Time of day to generate and send daily marketing reports (HH:MM format, UTC)
# Reports are generated for the previous day's data
# Default: "01:00" (1 AM UTC)
REPORT_GENERATION_TIME=01:00

# Number of days to look back for user activity in the User Summary Report
# Users with last_interaction_at within this many days will be included
# Set to 0 to include all users regardless of activity date
# Default: 30
REPORT_USER_ACTIVITY_DAYS=30

# Comma-separated list of email addresses to receive daily marketing reports
# If empty or not configured, reports will be generated but not delivered
# Example: marketing@example.com,analytics@example.com
REPORT_RECIPIENT_EMAILS=